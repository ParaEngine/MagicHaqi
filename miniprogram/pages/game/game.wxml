<web-view src="{{url}}" bindload="onWebLoad" binderror="onError" bindmessage="onWebMessage"></web-view>

<!-- 加载遮罩：覆盖在 web-view 之上，必须用 cover-view -->
<cover-view class="loading-mask" wx:if="{{loading}}">
  <cover-view class="loading-box">
    <cover-view class="spinner"></cover-view>
    <cover-view class="loading-text">加载中...</cover-view>
  </cover-view>
</cover-view>
