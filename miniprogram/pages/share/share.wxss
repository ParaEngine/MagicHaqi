.share-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
  box-sizing: border-box;
  background: radial-gradient(120% 80% at 50% 0%, #2a3a6e 0%, #16213e 45%, #0f1830 100%);
}

.card {
  width: 100%;
  max-width: 620rpx;
  background: rgba(20, 26, 48, 0.72);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 36rpx;
  padding: 64rpx 48rpx 56rpx;
  text-align: center;
  box-shadow: 0 24rpx 64rpx rgba(0, 0, 0, 0.45);
}

/* 顶部图标徽章（emoji 兜底） */
.icon-badge {
  width: 140rpx;
  height: 140rpx;
  margin: 0 auto 36rpx;
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, rgba(249, 168, 38, 0.25) 0%, rgba(255, 95, 162, 0.25) 100%);
  border: 1rpx solid rgba(255, 255, 255, 0.14);
}

.icon-emoji {
  font-size: 84rpx;
  line-height: 1;
}

/* 有封面图时展示封面 */
.cover {
  width: 200rpx;
  height: 200rpx;
  margin: 0 auto 36rpx;
  border-radius: 32rpx;
  display: block;
}

.brand {
  font-size: 26rpx;
  color: #8e9bc4;
  letter-spacing: 2rpx;
  margin-bottom: 14rpx;
}

.game-name {
  font-size: 46rpx;
  font-weight: 800;
  color: #ffffff;
  line-height: 1.25;
  margin-bottom: 22rpx;
  word-break: break-word;
}

.desc {
  font-size: 28rpx;
  color: #b9c2e0;
  line-height: 1.6;
  margin-bottom: 60rpx;
  word-break: break-word;
}

.share-btn {
  width: 100%;
  height: 96rpx;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 48rpx;
  background: linear-gradient(135deg, #f9a826 0%, #ff7a59 50%, #ff5fa2 100%);
  color: #1a1330;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1;
  border: none;
  box-shadow: 0 12rpx 32rpx rgba(255, 122, 89, 0.35);
}

.share-btn::after {
  border: none;
}

.share-btn-hover {
  opacity: 0.9;
  transform: translateY(2rpx);
}

.tip {
  font-size: 24rpx;
  color: #7e88ac;
  margin-top: 28rpx;
}

.back {
  margin-top: 44rpx;
  font-size: 28rpx;
  color: #9aa4c8;
  padding: 12rpx 32rpx;
}

/* 离屏 canvas：移出可视区域，仅用于生成分享封面图 */
.share-canvas {
  position: fixed;
  left: -9999rpx;
  top: -9999rpx;
  width: 500px;
  height: 400px;
}
