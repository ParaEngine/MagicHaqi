.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
  background: linear-gradient(160deg, #1a1a2e 0%, #16213e 60%, #0f3460 100%);
}

.title {
  font-size: 64rpx;
  font-weight: bold;
  color: #ffffff;
  letter-spacing: 4rpx;
}

.subtitle {
  margin-top: 12rpx;
  font-size: 32rpx;
  color: #a0a0c0;
}

.start-btn {
  margin-top: 80rpx;
  width: 360rpx;
  background: linear-gradient(90deg, #e94560, #ff6b81);
  color: #ffffff;
  border-radius: 48rpx;
  font-size: 34rpx;
  border: none;
}

.start-btn::after {
  border: none;
}

.tip {
  margin-top: 32rpx;
  font-size: 26rpx;
  color: #7070a0;
}
